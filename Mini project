<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Luxury Restaurant Menu</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
:root {
    --primary: #da08a9;
    --secondary: #4b4747;
    --bg: #f9f9f9;
}

* { box-sizing: border-box; }

body {
    margin: 0;
    font-family: 'Times New roman', Times, serif;
    background: var(--bg);
    color: #0b0b0b;
}


header {
    background: linear-gradient(135deg, var(--secondary), var(--primary));
    color: white;
    padding: 50px;
    text-align: center;
}


.nav {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 10px;
    padding: 15px;
    background: white;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

.nav a {
    text-decoration: none;
    padding: 10px 18px;
    border-radius: 20px;
    background: #eee;
    font-weight: bold;
    color: #333;
    transition: 0.3s;
}

.nav a:hover {
    background: var(--primary);
    color: white;
}


.container {
    max-width: 1200px;
    margin: auto;
    padding: 30px 20px;
}

.category h2 {
    color: var(--primary);
    margin-bottom: 20px;
}


.menu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
}

.card {
    background: white;
    border-radius: 15px;
    overflow: hidden;
    box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    transition: 0.3s;
}

.card:hover {
    transform: translateY(-6px);
}

.card img {
    width: 100%;
    height: 170px;
    object-fit: cover;
}

.card-body {
    padding: 15px;
}

.card-body h3 {
    margin: 0 0 8px 0;
}

.card-body p {
    margin: 0 0 10px 0;
}

.price {
    color: var(--primary);
    font-weight: bold;
}

.cart-toggle {
    display: none;
}

.cart-btn {
    display: inline-block;
    padding: 10px 22px;
    border-radius: 25px;
    background: linear-gradient(135deg, var(--primary), #e60000);
    color: white;
    font-weight: 600;
    cursor: pointer;
    box-shadow: 0 6px 16px rgba(179,0,0,0.35);
    transition: 0.3s;
}

.cart-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 22px rgba(179,0,0,0.55);
}

.cart-toggle:checked + .cart-btn {
    background: linear-gradient(135deg, #2e7d32, #4caf50);
}

.cart-toggle:checked + .cart-btn::before {
    content: "✔ Added ";
}


footer {
    background: var(--secondary);
    color: white;
    text-align: center;
    padding: 20px;
    margin-top: 40px;
}
</style>
</head>

<body>

<header>
<h1>Pours and Plate</h1>
<img src="ri.jpg" alt="Restaurant Image" style="width:100%;max-height:300px;object-fit:cover;margin-top:15px;">
<p>Premium Taste • Elegant Dining</p>
</header>

<div class="nav">
<a href="#starters">Starters</a>
<a href="#mains">Main Course</a>
</div>

<div class="container">

<!-- STARTERS -->
<div class="category" id="starters">
<h2>Starters</h2>
<div class="menu-grid">
<div class="card">
<img src="sr.jpg" alt="Spring Rolls">
<div class="card-body">
<h3>Spring Rolls</h3>
<p>Veg rolls</p>
<div class="price">Rs.599</div>
<input type="checkbox" id="c1" class="cart-toggle">
<label for="c1" class="cart-btn">🛒 Add to Cart</label>
</div>
</div>

<div class="card">
<img src="cw.jpg" alt="Chicken Wings">
<div class="card-body">
<h3>Chicken Wings</h3>
<p>Spicy grilled</p>
<div class="price">Rs.799</div>
<input type="checkbox" id="c2" class="cart-toggle">
<label for="c2" class="cart-btn">🛒 Add to Cart</label>
</div>
</div>

<div class="card">
<img src="gb.jpg" alt="Garlic Bread">
<div class="card-body">
<h3>Garlic Bread</h3>
<p>Cheesy & crispy</p>
<div class="price">Rs.499</div>
<input type="checkbox" id="c3" class="cart-toggle">
<label for="c3" class="cart-btn">🛒 Add to Cart</label>
</div>
</div>
</div>
</div>

<!-- MAIN COURSE -->
<div class="category" id="mains">
<h2>Main Course</h2>
<div class="menu-grid">
<div class="card">
<img src="gc.jpg" alt="Grilled Chicken">
<div class="card-body">
<h3>Grilled Chicken</h3>
<p>With fries</p>
<div class="price">Rs.129.9</div>
<input type="checkbox" id="c4" class="cart-toggle">
<label for="c4" class="cart-btn">🛒 Add to Cart</label>
</div>
</div>

<div class="card">
<img src="vp.jpg" alt="Veg Pasta">
<div class="card-body">
<h3>Veg Pasta</h3>
<p>Creamy sauce</p>
<div class="price">Rs.109.9</div>
<input type="checkbox" id="c5" class="cart-toggle">
<label for="c5" class="cart-btn">🛒 Add to Cart</label>
</div>
</div>

<div class="card">
<img src="bc.jpg" alt="Butter Chicken">
<div class="card-body">
<h3>Butter Chicken</h3>
<p>Indian classic</p>
<div class="price">Rs.139.9</div>
<input type="checkbox" id="c6" class="cart-toggle">
<label for="c6" class="cart-btn">🛒 Add to Cart</label>
</div>
</div>
</div>
</div>


<footer>
© 2026 Pours and Plate | Premium Taste • Elegant Dining
</footer>

</body>
</html>
